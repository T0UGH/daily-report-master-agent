{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hermes Run Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "host",
    "run_key",
    "report_date",
    "trigger",
    "previous_run_state"
  ],
  "properties": {
    "host": {
      "type": "string",
      "const": "hermes"
    },
    "run_key": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}:[a-z0-9-]+$"
    },
    "report_date": {
      "type": "string",
      "format": "date"
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "requested_by"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "cron",
            "manual"
          ]
        },
        "requested_by": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "previous_run_state": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/run_state"
        }
      ]
    }
  },
  "$defs": {
    "side_effect_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "succeeded",
            "failed",
            "skipped"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "reference": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "run_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_key",
        "report_date",
        "trigger_kind",
        "status",
        "last_verdict",
        "has_report_artifact",
        "publish_state",
        "archive_state"
      ],
      "properties": {
        "run_key": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}:[a-z0-9-]+$"
        },
        "report_date": {
          "type": "string",
          "format": "date"
        },
        "trigger_kind": {
          "type": "string",
          "enum": [
            "cron",
            "manual"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "running",
            "finished"
          ]
        },
        "last_verdict": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "normal",
            "degraded",
            "blocked",
            null
          ]
        },
        "has_report_artifact": {
          "type": "boolean"
        },
        "publish_state": {
          "$ref": "#/$defs/side_effect_state"
        },
        "archive_state": {
          "$ref": "#/$defs/side_effect_state"
        }
      }
    }
  }
}
